PORT=4000

# Multi-tenancy
# Set TENANT_ID to lock this deployment to a specific tenant (preferred in ECS).
# If unset, tenant is resolved from the X-Tenant-ID header or subdomain.
TENANT_ID=acme

# Cognito — values come from CDK outputs (UserPoolId, UserPoolClientId)
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
COGNITO_REGION=us-east-1

# DynamoDB
AWS_REGION=ap-south-1
# Table names are derived automatically: myschedlr-{TENANT_ID}-users
# Local dev only — omit in ECS (uses IAM role instead)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# DYNAMODB_ENDPOINT=http://localhost:8000   # for DynamoDB Local
